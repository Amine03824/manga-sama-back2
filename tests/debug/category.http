
// Récupéprer toutes les catégories .getAllCategories
GET  http://localhost:3000/category HTTP/1.1

###
// Ajouter une catégorie .createOneCategory
POST  http://localhost:3000/category HTTP/1.1
Content-Type: application/json

{
"category_name":"Hentaï"
}
###
// Obtenir les informations d'une catégorie .getOneCategoryById
GET http://localhost:3000/category/7 HTTP/1.1

###
// Modifier une catégorie .modifyOneCategoryById
PATCH http://localhost:3000/category/7 HTTP/1.1
Content-Type: application/json

{
  "category_name": "Hentaï de la muerte"
}

###
// Supprimer une catégorie .removeOneCategoryById
DELETE  http://localhost:3000/category/7 HTTP/1.1